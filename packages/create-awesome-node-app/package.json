{
  "name": "create-awesome-node-app",
  "version": "0.11.3",
  "type": "module",
  "description": "Composable scaffolding CLI for production-ready Node, Web, Full-Stack, Monorepo, and AI-ready projects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Create-Node-App/create-node-app.git"
  },
  "bugs": {
    "url": "https://github.com/Create-Node-App/create-node-app/issues"
  },
  "homepage": "https://create-awesome-node-app.vercel.app",
  "keywords": [
    "create",
    "scaffold",
    "scaffolding",
    "starter",
    "template",
    "node",
    "nodejs",
    "typescript",
    "react",
    "nextjs",
    "nestjs",
    "vite",
    "monorepo",
    "turborepo",
    "cli",
    "code-generator",
    "project-generator",
    "boilerplate",
    "ai-ready",
    "agents-md",
    "typescript-first",
    "production-ready",
    "rapid-prototyping",
    "project-scaffolding",
    "remix",
    "astro",
    "hono"
  ],
  "authors": [
    {
      "name": "Ulises Jeremias Cornejo Fandos",
      "email": "ulisescf.24@gmail.com"
    }
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "index.js",
    "dist/**",
    "assets/**",
    "README.md"
  ],
  "bin": {
    "create-awesome-node-app": "index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "scope": "@create-node-app"
  },
  "scripts": {
    "build": "tsup src/index.ts src/templates.ts --format cjs,esm --dts --sourcemap",
    "dev": "tsup src/index.ts src/templates.ts --watch --format cjs,esm --dts --sourcemap",
    "type-check": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx,js}' --fix",
    "test": "tsx --test tests/**/*.test.mts",
    "test:src": "npm run test"
  },
  "dependencies": {
    "@create-node-app/core": "^0.7.4",
    "ci-info": "^4.4.0",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@create-node-app/core": "^0.7.4",
    "@types/node": "^26.1.1",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.5.8",
    "eslint": "^10.6.0",
    "nock": "^14.0.15",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4"
  }
}
