{
  "name": "@create-node-app/core",
  "version": "0.7.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Create-Node-App/create-node-app.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "scope": "@create-node-app"
  },
  "scripts": {
    "lint": "eslint '**/*.{ts,tsx,js}'",
    "lint:fix": "eslint '**/*.{ts,tsx,js}' --fix",
    "type-check": "tsc --noEmit",
    "build": "tsup ./index.ts --format esm,cjs --dts --no-splitting --sourcemap --platform node --shims",
    "dev": "tsup ./index.ts --format esm,cjs --watch --dts --no-splitting --sourcemap",
    "test": "tsx --test tests/**/*.test.mts"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/debug": "^4.1.13",
    "@types/ms": "^2.1.0",
    "@types/envinfo": "^7.8.4",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^26.1.0",
    "@types/semver": "^7.5.8",
    "eslint": "^10.6.0",
    "tsconfig": "*",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "debug": "^4.4.3",
    "envinfo": "^7.21.0",
    "fs-extra": "^11.3.6",
    "lodash": "^4.6.2",
    "lodash.merge": "^4.6.2",
    "picocolors": "^1.0.0",
    "readdirp": "^5.0.0",
    "semver": "^7.8.5",
    "simple-git": "^3.36.0"
  }
}
